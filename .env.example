# =============================================================================
# Bekasen — Environment Variables Template
# Copy this file to `.env.local` for development.
# Generate JWT secrets with: openssl rand -base64 32
# =============================================================================

# --- Database -----------------------------------------------------------------
DATABASE_URL=postgres://bekasen:dev@localhost:5432/bekasen

# --- Site ---------------------------------------------------------------------
SITE_URL=http://localhost:3000
NODE_ENV=development

# --- Admin (used only by seed script + middleware) ----------------------------
ADMIN_EMAIL=jwadson666@gmail.com
# Leave empty to auto-generate a 12-char nanoid on first seed run.
# Once set, do not change without rotating the panel URL.
ADMIN_PANEL_UID=

# --- Auth secrets (REQUIRED in production) ------------------------------------
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- AI (OpenRouter) ----------------------------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=PLACEHOLDER
OPENROUTER_MODEL=anthropic/claude-3-haiku
OPENROUTER_REFERER=https://bekasen.com

# --- Email (Resend) -----------------------------------------------------------
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=PLACEHOLDER
EMAIL_FROM=Bekasen <noreply@bekasen.com>
EMAIL_NOTIFY_TO=jwadson666@gmail.com

# --- Cal.com (already wired in lib/contact.ts, here for reference) ------------
CAL_USERNAME=bekasen-ytjx1n

# --- Rate limits (overridable per env) ----------------------------------------
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MIN=15
RATE_LIMIT_CHATBOT_MAX=3
RATE_LIMIT_CHATBOT_WINDOW_HOURS=1
RATE_LIMIT_CLIENT_VIEW_MAX=30
RATE_LIMIT_CLIENT_VIEW_WINDOW_MIN=1
