# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
.env.development.local
.env.test.local
# Note: .env.example IS committed (template)

# user-uploaded files (managed by CMS, not source)
/public/uploads/*
!/public/uploads/.gitkeep

# vercel
.vercel

/_docs
# typescript
*.tsbuildinfo
next-env.d.ts

# next-sitemap generated artifacts (regenerated on each build via postbuild hook)
/public/sitemap.xml
/public/sitemap-*.xml
/public/robots.txt

# local-only implementation status doc (cheat-sheet)
IMPLEMENTATION_STATUS.md

# local-only ops runbook (printed + put in the bus-factor envelope)
MAINTENANCE.md
INCIDENTS.md
